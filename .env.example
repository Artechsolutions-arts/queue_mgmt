# ------------------------------------------------------------
# Local-dev defaults. DO NOT use these values in production.
# In production: copy to .env and replace every secret.
# ------------------------------------------------------------

# Profile: dev | prod | test
DJANGO_ENV=dev

# Database
POSTGRES_DB=hospital_queue
POSTGRES_USER=hospital
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://hospital:changeme@db:5432/hospital_queue

# Redis
REDIS_URL=redis://redis:6379/0

# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=django-insecure-dev-only-change-me
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=
DJANGO_CSRF_TRUSTED_ORIGINS=

# JWT
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=7

# DRF throttling (override in prod for tighter limits)
THROTTLE_ANON=60/min
THROTTLE_USER=600/min
THROTTLE_REGISTER=20/min
THROTTLE_LOGIN=10/min
THROTTLE_STATUS=120/min

# Default staff account (created by `make seed`)
STAFF_USERNAME=staff
STAFF_PASSWORD=staffpass123

# Twilio — leave SID/TOKEN blank to mock; set NOTIFICATION_MOCK_ENABLED=false in prod
NOTIFICATION_MOCK_ENABLED=true
NOTIFICATION_LOG_BODIES=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890
# WhatsApp approved-template Content SIDs (HX...). Leave blank to send free-form
# (sandbox / inside the 24h window only). Required for a production sender.
#   _CONTENT_SID        → single-token register (vars: service, token, eta, directions)
#   _BUNDLE_CONTENT_SID → multi-token register-multi (vars: name, count, first stop, all stops)
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_WHATSAPP_BUNDLE_CONTENT_SID=

# Sentry — leave SENTRY_DSN blank to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.05

# Hospital config
HOSPITAL_LAYOUT_TEMPLATE=default
WAIT_TIME_THRESHOLD_AMBER=10
WAIT_TIME_THRESHOLD_RED=20
STATS_WINDOW_HOURS=24

# AI / MLflow
MODEL_VERSION=v1
MLFLOW_TRACKING_URI=http://mlflow:5000
GROQ_API_KEY=

# Frontends (browser-facing URLs — adjust for prod domains)
VITE_API_BASE=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws/queue/
VITE_WS_PATIENT_BASE=ws://localhost:8000/ws/patient/
VITE_HOSPITAL_NAME=General City Hospital

# Vision frame store (rolling forensic buffer)
FRAME_STORE_ENABLED=true
FRAME_STORE_INTERVAL_SECONDS=5
FRAME_STORE_WINDOW_SECONDS=1800
# Channel strategy: fallback (SMS only if WhatsApp fails) | always | off
NOTIFICATION_SMS_MODE=fallback
